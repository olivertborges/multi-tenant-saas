generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  roles Role[]
}

model Role {
  id          String   @id @default(uuid())
  name        String   // ADMIN, MANAGER, EMPLOYEE, VIEWER
  description String?
  permissions Json     @default("[]") // ["users:read", "users:write", "billing:read", ...]
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  users  User[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

model User {
  id        String   @id @default(uuid())
  email     String
  name      String
  password  String
  roleId    String
  tenantId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([roleId])
}
