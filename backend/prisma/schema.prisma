generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  logo      String?
  theme     Json     @default("{\"primary\":\"#6366f1\",\"secondary\":\"#8b5cf6\"}")
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  roles     Role[]
  services  Service[]
  products  Product[]
  agendas   Agenda[]
  purchases Purchase[]
  carts     Cart[]
  coupons   Coupon[]
}

model User {
  id             String   @id @default(uuid())
  email          String
  name           String
  password       String
  roleId         String
  tenantId       String
  points         Int      @default(0)
  avatar         String?
  phone          String?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  membershipLevel String  @default("BRONZE")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  role        Role        @relation(fields: [roleId], references: [id])
  agendas     Agenda[]
  purchases   Purchase[]
  pointsLog   PointsLog[]
  cart        Cart?
  couponUsages CouponUsage[]
  wishlist    Wishlist[]   // ← Agregado

  @@unique([email, tenantId])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions Json     @default("[]")
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  users  User[]

  @@unique([name, tenantId])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  duration    Int      @default(60)
  price       Float
  category    String?
  image       String?
  isActive    Boolean  @default(true)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  agendas Agenda[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  category    String?
  images      Json     @default("[]")
  isActive    Boolean  @default(true)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  cartItems      CartItem[]
  purchaseItems  PurchaseItem[]
  wishlist       Wishlist[]     // ← Agregado

  @@index([tenantId])
}

model Agenda {
  id          String   @id @default(uuid())
  userId      String
  serviceId   String
  tenantId    String
  date        DateTime
  time        String
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id])
  tenant Tenant     @relation(fields: [tenantId], references: [id])
  items  CartItem[]

  @@index([userId])
  @@index([tenantId])
}

model CartItem {
  id         String   @id @default(uuid())
  cartId     String
  productId  String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Purchase {
  id          String   @id @default(uuid())
  userId      String
  tenantId    String
  total       Float
  status      String   @default("PENDING")
  paymentMethod String?
  pointsUsed  Int      @default(0)
  pointsEarned Int     @default(0)
  couponCode  String?
  discountAmount Float @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id])
  tenant Tenant        @relation(fields: [tenantId], references: [id])
  items  PurchaseItem[]
  couponUsages CouponUsage[]

  @@index([userId])
  @@index([tenantId])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  price      Float
  createdAt  DateTime @default(now())

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model PointsLog {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  type      String
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  description  String?
  discountType String
  discountValue Float
  minPurchase  Float?
  maxDiscount  Float?
  usageLimit   Int?
  usedCount    Int      @default(0)
  validFrom    DateTime
  validUntil   DateTime
  isActive     Boolean  @default(true)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  usages CouponUsage[]

  @@index([code])
  @@index([tenantId])
}

model CouponUsage {
  id         String   @id @default(uuid())
  couponId   String
  userId     String
  purchaseId String?
  usedAt     DateTime @default(now())

  coupon   Coupon   @relation(fields: [couponId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@unique([couponId, userId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}
